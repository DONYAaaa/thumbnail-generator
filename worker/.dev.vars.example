# Copy to .dev.vars (gitignored) for local dev.
FAL_KEY=

# Optional. Public base URL returned in GET /config as { "workerUrl": "..." }.
# The widget uses that value for /analyze, /generate, /upload (embeds, tunnels, custom domains).
# If unset or empty, /config uses the incoming request origin (fine when you open the app at the Worker URL).
# WIDGET_PUBLIC_URL=https://your-worker.example.com
